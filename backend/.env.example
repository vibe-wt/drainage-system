APP_NAME=Drainage System API
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/drainage_system

# Comma-separated origins for local frontend worktrees and deployments.
CORS_ORIGINS=http://localhost:4173,http://localhost:4174,http://localhost:4175,http://localhost:4176,http://localhost:4177
CORS_ORIGIN_REGEX=http://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0):4\\d{3}

SESSION_COOKIE_NAME=drainage_session
SESSION_TTL_HOURS=12
SESSION_SECURE_COOKIES=false

SEED_ADMIN_EMAIL=admin@drainage.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=System Admin
